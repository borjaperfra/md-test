generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Offer {
  id          String      @id @default(cuid())
  title       String
  company     String
  type        OfferType
  modality    Modality
  salary      String?
  url         String
  shortUrl    String?
  status      OfferStatus @default(pending)
  order       Int?
  notes       String?
  isFreelance Boolean     @default(false)
  location    String?
  publishedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  dailyPostId String?
  dailyPost   DailyPost?  @relation(fields: [dailyPostId], references: [id])
}

model DailyPost {
  id          String    @id @default(cuid())
  date        DateTime  @default(now())
  message     String?
  milestone   String?
  postedAt    DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  offers      Offer[]
}

model Milestone {
  id          String    @id @default(cuid())
  text        String
  date        DateTime  @default(now())
  createdAt   DateTime  @default(now())
}

model SourceUrl {
  id          String    @id @default(cuid())
  name        String
  url         String
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum OfferType {
  manfred
  client
  external
}

enum Modality {
  remote
  hybrid
  onsite
}

enum OfferStatus {
  pending
  selected
  discarded
}

model ScheduledMessage {
  id          String          @id @default(cuid())
  message     String
  offerIds    String?         // JSON array of offer IDs included in this message
  scheduledAt DateTime?
  sentAt      DateTime?
  status      MessageStatus   @default(pending)
  telegramId      String?
  views           Int?            // Snapshot of views saved before message deletion
  offersSnapshot  String?         // JSON: [{id,title,company,salary,shortUrl}] for imported/historical messages
  createdBy   String?         // Email of the user who created/scheduled the message
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum MessageStatus {
  pending
  sent
  failed
  cancelled
}

model Feedback {
  id        String   @id @default(cuid())
  text      String
  author    String?
  reviewed  Boolean  @default(false)
  createdAt DateTime @default(now())
}
