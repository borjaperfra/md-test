# Base de datos (Supabase o cualquier PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database

# URL de la app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Anthropic — necesario para buscar ofertas y leer URLs
# Consíguelo en: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Bit.ly — opcional, acorta URLs en el mensaje de Telegram
# Consíguelo en: https://app.bitly.com/settings/api
BITLY_API_KEY=

# Telegram Bot — necesario para enviar/programar mensajes
# 1. Crea un bot con @BotFather en Telegram
# 2. Obtén el chat ID visitando: https://api.telegram.org/bot{TOKEN}/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
