# Base de datos (Supabase o cualquier PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/database

# URL de la app (en Railway, la URL que te asignen)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Claude (Anthropic) — para analizar URLs de ofertas
ANTHROPIC_API_KEY=sk-ant-...

# Bit.ly — acorta URLs en el mensaje de Telegram
# Consíguelo en: https://app.bitly.com/settings/api
BITLY_API_KEY=

# Telegram Bot — para enviar/programar mensajes
# 1. Crea un bot con @BotFather en Telegram
# 2. Añádelo al canal como administrador
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=@tucanal

# Auth (NextAuth + Google OAuth)
# NEXTAUTH_SECRET: genera con: openssl rand -base64 32
# GOOGLE_CLIENT_ID / SECRET: en console.cloud.google.com → APIs → Credenciales
NEXTAUTH_URL=https://tu-app.railway.app
NEXTAUTH_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Cron secret (cualquier string aleatorio largo, p.ej. openssl rand -base64 32)
CRON_SECRET=

# Slack — notificaciones de envío y errores del cron
# Crea un Incoming Webhook en: api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=
